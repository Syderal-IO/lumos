# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example for collaborators)
.env*
!.env.example

# Anchor / Solana
contracts/target/
contracts/.anchor/
contracts/node_modules/
*.so

# Python
__pycache__/
*.pyc
intelligence/.venv/

# Keypairs (NEVER commit)
*-keypair.json
id.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
