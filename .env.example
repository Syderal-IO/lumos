# Green-Ledger — Environment Variables
# Copy this file to .env.local and fill in your keys
# ═══════════════════════════════════════

# Kimi K2.6 (Moonshot AI — OpenAI-compatible)
# Get your key at: https://platform.moonshot.cn/
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# Python Intelligence Service (TimesFM + Graphify)
# Start with: cd intelligence && python main.py
INTELLIGENCE_URL=http://localhost:8000

# Solana Devnet — NexusVault is already deployed!
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=
NEXUSVAULT_PROGRAM_ID=5VaMiFyzNEewHFSPeB69JNvDAkkL3XByjepgKjjSbMSn
SOLANA_NETWORK=devnet

# Mapbox (public — exposed to browser)
# Get your token at: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Solana RPC (public — exposed to browser for wallet connection)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
